# Supabase (client) - used by the web app
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# Supabase (server) - service role (DO NOT COMMIT real keys)
SUPABASE_SERVICE_ROLE_KEY=

# HealthLens sync secret for Android companion (shared secret)
HEALTHLENS_SYNC_SECRET=

# Public URL of your deployed HealthLens instance
BASE_URL=

# Strava exercise-source connector (server-side; do not commit real secrets)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_VERIFY_TOKEN=
STRAVA_WEBHOOK_CALLBACK_URL=https://health-lens-rust.vercel.app/api/strava/webhook
STRAVA_REDIRECT_URI=https://health-lens-rust.vercel.app/api/strava/callback
STRAVA_SCOPES=read,activity:read

# Default user id for single-user/dev mode
DEFAULT_USER_ID=local-user
